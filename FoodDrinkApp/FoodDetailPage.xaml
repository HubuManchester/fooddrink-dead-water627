<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:FoodDrinkApp.Models"
             x:Class="FoodDrinkApp.FoodDetailPage"
             x:DataType="models:FoodModel"
             Title="Nutrition Details"
             BackgroundColor="{AppThemeBinding Light=#FFF9EF, Dark=#0F1711}"
             SemanticProperties.Description="Food detail — nutrition breakdown and macros">

    <ScrollView SemanticProperties.Description="Scrollable nutrition detail dashboard">
        <VerticalStackLayout Padding="20" Spacing="16">

            <!-- ══════════════ Calorie Alert Banner ══════════════ -->
            <Border StrokeThickness="1"
                    Padding="14"
                    Stroke="{Binding CalorieAlertTextColor}"
                    BackgroundColor="{Binding CalorieAlertBackground}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14" />
                </Border.StrokeShape>
                <Label Text="{Binding CalorieAlertText}"
                       FontSize="16" FontAttributes="Bold"
                       HorizontalTextAlignment="Center"
                       TextColor="{Binding CalorieAlertTextColor}"
                       SemanticProperties.Description="Calorie intake assessment" />
            </Border>

            <!-- ══════════════ Food Identity Card ══════════════ -->
            <Border StrokeThickness="1" Padding="20"
                    Stroke="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#1A1712}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#18000000" Offset="0,2" Radius="8" Opacity="0.22" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="12">

                    <!-- Food Name -->
                    <Label Text="{Binding Name}"
                           FontSize="28" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#3A2518, Dark=#FFF2DF}"
                           SemanticProperties.HeadingLevel="Level1"
                           SemanticProperties.Description="Dish or drink name" />

                    <!-- Rating Stars -->
                    <Label Text="{Binding RatingLabel}"
                           FontSize="18"
                           TextColor="{AppThemeBinding Light=#D9472B, Dark=#FF9C7B}"
                           SemanticProperties.Description="Star rating" />

                    <!-- Calorie Value -->
                    <Label Text="{Binding CaloriesLabel}"
                           FontSize="26" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#D9472B, Dark=#FF9C7B}"
                           SemanticProperties.Description="Total calorie count" />

                    <BoxView HeightRequest="1"
                             Color="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}" />

                    <!-- Restaurant Name -->
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Label Text="📍"
                               FontSize="16"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="{Binding RestaurantName, TargetNullValue='(Home cooking)'}"
                               FontSize="16"
                               TextColor="{AppThemeBinding Light=#6E5A47, Dark=#D8C4AC}"
                               VerticalOptions="Center"
                               SemanticProperties.Description="Restaurant or location" />
                    </Grid>

                    <!-- Dined Date -->
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Label Text="📅"
                               FontSize="16"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="{Binding DateLabel}"
                               FontSize="16"
                               TextColor="{AppThemeBinding Light=#6E5A47, Dark=#D8C4AC}"
                               VerticalOptions="Center"
                               SemanticProperties.Description="Date the meal was recorded" />
                    </Grid>

                    <!-- Location -->
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Label Text="🌍"
                               FontSize="16"
                               VerticalOptions="Start" />
                        <Label Grid.Column="1"
                               Text="{Binding Location, TargetNullValue='(No location recorded)'}"
                               FontSize="15"
                               TextColor="{AppThemeBinding Light=#6E5A47, Dark=#D8C4AC}"
                               SemanticProperties.Description="Dining location" />
                    </Grid>

                    <!-- Review / User Notes -->
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Label Text="📝"
                               FontSize="16"
                               VerticalOptions="Start" />
                        <Label Grid.Column="1"
                               Text="{Binding Review}"
                               FontSize="15"
                               TextColor="{AppThemeBinding Light=#6E5A47, Dark=#D8C4AC}"
                               SemanticProperties.Description="Personal notes and review" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- ══════════════ Macro Badges Card ══════════════ -->
            <Border StrokeThickness="1" Padding="18"
                    Stroke="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#1A1712}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#18000000" Offset="0,2" Radius="8" Opacity="0.22" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="12">

                    <Label Text="🧬  Macro Analysis"
                           FontSize="18" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#2F7A4F, Dark=#8CE6A1}"
                           SemanticProperties.HeadingLevel="Level2" />

                    <BoxView HeightRequest="1"
                             Color="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}" />

                    <!-- Three macro badges -->
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">

                        <!-- Protein badge -->
                        <Border StrokeThickness="1" Padding="10,12"
                                Stroke="#FF6384"
                                BackgroundColor="{AppThemeBinding Light=#FFF0F3, Dark=#2A1A1E}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                <Label Text="Protein"
                                       FontSize="11"
                                       HorizontalTextAlignment="Center"
                                       TextColor="{AppThemeBinding Light=#8B6D55, Dark=#BFA58E}" />
                                <Label Text="{Binding ProteinLevel}"
                                       FontSize="16" FontAttributes="Bold"
                                       HorizontalTextAlignment="Center"
                                       TextColor="#FF6384" />
                                <Label FontSize="12"
                                       HorizontalTextAlignment="Center"
                                       TextColor="{AppThemeBinding Light=#6E5A47, Dark=#D8C4AC}">
                                    <Label.Text>
                                        <Binding Path="Protein" StringFormat="{}{0}g" FallbackValue="0g" />
                                    </Label.Text>
                                </Label>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Carbs badge -->
                        <Border Grid.Column="1" StrokeThickness="1" Padding="10,12"
                                Stroke="#FFCE56"
                                BackgroundColor="{AppThemeBinding Light=#FFF9EC, Dark=#2A2417}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                <Label Text="Carbs"
                                       FontSize="11"
                                       HorizontalTextAlignment="Center"
                                       TextColor="{AppThemeBinding Light=#8B6D55, Dark=#BFA58E}" />
                                <Label Text="{Binding CarbsLevel}"
                                       FontSize="16" FontAttributes="Bold"
                                       HorizontalTextAlignment="Center"
                                       TextColor="#FFCE56" />
                                <Label FontSize="12"
                                       HorizontalTextAlignment="Center"
                                       TextColor="{AppThemeBinding Light=#6E5A47, Dark=#D8C4AC}">
                                    <Label.Text>
                                        <Binding Path="Carbs" StringFormat="{}{0}g" FallbackValue="0g" />
                                    </Label.Text>
                                </Label>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Fat badge -->
                        <Border Grid.Column="2" StrokeThickness="1" Padding="10,12"
                                Stroke="#36A2EB"
                                BackgroundColor="{AppThemeBinding Light=#F0F7FF, Dark=#171F2A}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                <Label Text="Fat"
                                       FontSize="11"
                                       HorizontalTextAlignment="Center"
                                       TextColor="{AppThemeBinding Light=#8B6D55, Dark=#BFA58E}" />
                                <Label Text="{Binding FatLevel}"
                                       FontSize="16" FontAttributes="Bold"
                                       HorizontalTextAlignment="Center"
                                       TextColor="#36A2EB" />
                                <Label FontSize="12"
                                       HorizontalTextAlignment="Center"
                                       TextColor="{AppThemeBinding Light=#6E5A47, Dark=#D8C4AC}">
                                    <Label.Text>
                                        <Binding Path="Fat" StringFormat="{}{0}g" FallbackValue="0g" />
                                    </Label.Text>
                                </Label>
                            </VerticalStackLayout>
                        </Border>

                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- ══════════════ Nutrition Summary Card ══════════════ -->
            <Border StrokeThickness="1" Padding="18"
                    Stroke="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#1A1712}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#18000000" Offset="0,2" Radius="8" Opacity="0.22" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="10">
                    <Label Text="{Binding NutritionSummary}"
                           FontSize="15"
                           TextColor="{AppThemeBinding Light=#2F7A4F, Dark=#8CE6A1}"
                           SemanticProperties.Description="Macronutrient summary" />
                    <Label Text="{Binding Tags, StringFormat='🏷️ {0}'}"
                           FontSize="13"
                           TextColor="{AppThemeBinding Light=#8B6D55, Dark=#BFA58E}"
                           SemanticProperties.Description="Search tags" />
                </VerticalStackLayout>
            </Border>

            <!-- Bottom spacer -->
            <BoxView HeightRequest="12" Color="Transparent" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
