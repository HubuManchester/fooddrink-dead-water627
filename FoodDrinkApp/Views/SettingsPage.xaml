<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FoodDrinkApp.ViewModels"
             x:Class="FoodDrinkApp.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="{Binding Title}"
             BackgroundColor="{AppThemeBinding Light=#FFF9EF, Dark=#0F1711}"
             SemanticProperties.Description="Advanced settings — personalise your app experience">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <!-- ═══════════════════════════════════════════
                 HEADER
                 ═══════════════════════════════════════════ -->
            <VerticalStackLayout Spacing="4">
                <Label Text="⚙️  Settings"
                       FontSize="26" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#D9472B, Dark=#FF9C7B}"
                       SemanticProperties.HeadingLevel="Level1"
                       SemanticProperties.Description="App settings and personalisation options" />
                <Label Text="Customise your NutriBite experience."
                       FontSize="15"
                       TextColor="{AppThemeBinding Light=#8B6D55, Dark=#D8C4AC}"
                       SemanticProperties.Description="Adjust preferences, accessibility, and data options below" />
            </VerticalStackLayout>

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               HeightRequest="28"
                               Color="{AppThemeBinding Light=#D9472B, Dark=#FF9C7B}" />

            <!-- ═══════════════════════════════════════════
                 PREFERENCES CARD
                 ═══════════════════════════════════════════ -->
            <Border StrokeThickness="1" Padding="18"
                    Stroke="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#1A1712}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="16">

                    <!-- Section heading -->
                    <VerticalStackLayout Spacing="2">
                        <Label Text="🎨  Preferences"
                               FontSize="18" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#D9472B, Dark=#FF9C7B}"
                               SemanticProperties.HeadingLevel="Level2" />
                        <Label Text="Control how the app looks and behaves."
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#8B6D55, Dark=#BFA58E}" />
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1"
                             Color="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}" />

                    <!-- Dark Mode -->
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Dark Mode"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#3A2518, Dark=#FFF2DF}" />
                            <Label Text="Switch between light and dark colour themes."
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light=#8B6D55, Dark=#BFA58E}" />
                        </VerticalStackLayout>
                        <Switch Grid.Column="1"
                                IsToggled="{Binding IsDarkMode}"
                                OnColor="{AppThemeBinding Light=#D9472B, Dark=#FF9C7B}"
                                SemanticProperties.Hint="Enable or disable dark colour scheme" />
                    </Grid>

                    <BoxView HeightRequest="1"
                             Color="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}" />

                    <!-- Push Notifications -->
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Push Notifications"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#3A2518, Dark=#FFF2DF}" />
                            <Label Text="Receive alerts about meal reminders and tips."
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light=#8B6D55, Dark=#BFA58E}" />
                        </VerticalStackLayout>
                        <Switch Grid.Column="1"
                                IsToggled="{Binding IsPushEnabled}"
                                OnColor="{AppThemeBinding Light=#D9472B, Dark=#FF9C7B}"
                                SemanticProperties.Hint="Enable or disable push notifications" />
                    </Grid>

                    <BoxView HeightRequest="1"
                             Color="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}" />

                    <!-- High Contrast Mode (WCAG) -->
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="High Contrast Mode"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#3A2518, Dark=#FFF2DF}" />
                            <Label Text="Enhances text readability for improved accessibility (WCAG AA/AAA aligned)."
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light=#8B6D55, Dark=#BFA58E}" />
                        </VerticalStackLayout>
                        <Switch Grid.Column="1"
                                IsToggled="{Binding IsHighContrast}"
                                OnColor="{AppThemeBinding Light=#D9472B, Dark=#FF9C7B}"
                                SemanticProperties.Hint="Enable high contrast for improved readability"
                                SemanticProperties.Description="WCAG accessibility — high contrast display mode" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- ═══════════════════════════════════════════
                 NUTRITION GOAL CARD
                 ═══════════════════════════════════════════ -->
            <Border StrokeThickness="1" Padding="18"
                    Stroke="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#1A1712}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="16">

                    <!-- Section heading -->
                    <VerticalStackLayout Spacing="2">
                        <Label Text="🎯  Nutrition Goal"
                               FontSize="18" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#2F7A4F, Dark=#8CE6A1}"
                               SemanticProperties.HeadingLevel="Level2" />
                        <Label Text="Sets your daily calorie target — synergises with Statistics and Profile dashboards."
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#8B6D55, Dark=#BFA58E}" />
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1"
                             Color="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}" />

                    <!-- Current goal display -->
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                        <Label Text="Daily Calorie Goal"
                               FontSize="16" FontAttributes="Bold"
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light=#3A2518, Dark=#FFF2DF}" />
                        <Label Grid.Column="1"
                               FontSize="22" FontAttributes="Bold"
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light=#D9472B, Dark=#FF9C7B}">
                            <Label.Text>
                                <Binding Path="DailyCalorieGoal"
                                         StringFormat="{}{0} kcal"
                                         FallbackValue="2000 kcal" />
                            </Label.Text>
                        </Label>
                    </Grid>

                    <!-- Slider for quick adjustment -->
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                        <Label Text="500"
                               FontSize="11"
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light=#8B6D55, Dark=#BFA58E}" />
                        <Slider Grid.Column="1"
                                Minimum="500" Maximum="5000"
                                Value="{Binding DailyCalorieGoal}"
                                MinimumTrackColor="{AppThemeBinding Light=#D9472B, Dark=#FF9C7B}"
                                MaximumTrackColor="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}"
                                ThumbColor="{AppThemeBinding Light=#D9472B, Dark=#FF9C7B}"
                                SemanticProperties.Hint="Slide to adjust daily calorie goal between 500 and 5000" />
                        <Label Grid.Column="2" Text="5000"
                               FontSize="11"
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light=#8B6D55, Dark=#BFA58E}" />
                    </Grid>

                    <!-- Manual entry for precise value -->
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                        <Label Text="Exact value:"
                               FontSize="14"
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light=#3A2518, Dark=#FFF2DF}" />
                        <Entry Grid.Column="1"
                               Text="{Binding DailyCalorieGoal}"
                               Keyboard="Numeric"
                               HorizontalTextAlignment="Center"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#D9472B, Dark=#FF9C7B}"
                               PlaceholderColor="{AppThemeBinding Light=#BFA58E, Dark=#6E5A47}"
                               SemanticProperties.Hint="Enter exact daily calorie goal as a number" />
                        <Label Grid.Column="2" Text="kcal"
                               FontSize="14"
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light=#8B6D55, Dark=#BFA58E}" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- ═══════════════════════════════════════════
                 LOCALISATION CARD
                 ═══════════════════════════════════════════ -->
            <Border StrokeThickness="1" Padding="18"
                    Stroke="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#1A1712}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="16">

                    <!-- Section heading -->
                    <VerticalStackLayout Spacing="2">
                        <Label Text="🌍  Unit Preferences"
                               FontSize="18" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#F29B38, Dark=#FFB15D}"
                               SemanticProperties.HeadingLevel="Level2" />
                        <Label Text="Choose your preferred energy measurement unit."
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#8B6D55, Dark=#BFA58E}" />
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1"
                             Color="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}" />

                    <!-- Energy Unit Toggle -->
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Energy Unit"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#3A2518, Dark=#FFF2DF}" />
                            <Label Text="Toggle to switch between kilocalories (kcal) and kilojoules (kJ)."
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light=#8B6D55, Dark=#BFA58E}" />
                        </VerticalStackLayout>
                        <HorizontalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                            <Label Text="kcal"
                                   FontSize="15" FontAttributes="Bold"
                                   VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light=#D9472B, Dark=#FF9C7B}" />
                            <Switch IsToggled="{Binding UseKilojoules}"
                                    OnColor="{AppThemeBinding Light=#F29B38, Dark=#FFB15D}"
                                    SemanticProperties.Hint="Toggle between kilocalories (kcal) and kilojoules (kJ)" />
                            <Label Text="kJ"
                                   FontSize="15" FontAttributes="Bold"
                                   VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light=#F29B38, Dark=#FFB15D}" />
                        </HorizontalStackLayout>
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- ═══════════════════════════════════════════
                 SECURITY & PRIVACY CARD
                 ═══════════════════════════════════════════ -->
            <Border StrokeThickness="1" Padding="18"
                    Stroke="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#1A1712}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#18000000" Offset="0,2" Radius="8" Opacity="0.22" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="16">

                    <!-- Section heading -->
                    <VerticalStackLayout Spacing="2">
                        <Label Text="🔒  Security &amp; Privacy"
                               FontSize="18" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#2F7A4F, Dark=#8CE6A1}"
                               SemanticProperties.HeadingLevel="Level2" />
                        <Label Text="Protect your food diary with device-level authentication."
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#8B6D55, Dark=#BFA58E}" />
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1"
                             Color="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}" />

                    <!-- Biometric Authentication Toggle -->
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Enable Biometric Authentication (Face ID / Touch ID)"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#3A2518, Dark=#FFF2DF}" />
                            <Label Text="When enabled, your food logs require biometric verification to access."
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light=#8B6D55, Dark=#BFA58E}" />
                        </VerticalStackLayout>
                        <Switch Grid.Column="1"
                                IsToggled="{Binding IsBiometricEnabled}"
                                OnColor="{AppThemeBinding Light=#2F7A4F, Dark=#8CE6A1}"
                                SemanticProperties.Hint="Require Face ID or fingerprint to open the app"
                                SemanticProperties.Description="Toggle biometric lock for food diary privacy" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- ═══════════════════════════════════════════
                 DATA MANAGEMENT CARD
                 ═══════════════════════════════════════════ -->
            <Border StrokeThickness="1" Padding="18"
                    Stroke="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#1A1712}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="16">

                    <!-- Section heading -->
                    <VerticalStackLayout Spacing="2">
                        <Label Text="💾  Data Management"
                               FontSize="18" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#6A5ACD, Dark=#B8A9FF}"
                               SemanticProperties.HeadingLevel="Level2" />
                        <Label Text="Export your data or free up local storage."
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#8B6D55, Dark=#BFA58E}" />
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1"
                             Color="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}" />

                    <!-- Export Data -->
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Export Data to CSV"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#3A2518, Dark=#FFF2DF}" />
                            <Label Text="Download your food log as a CSV spreadsheet for offline analysis."
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light=#8B6D55, Dark=#BFA58E}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1"
                                Text="📤 Export"
                                FontAttributes="Bold" FontSize="13"
                                BackgroundColor="{AppThemeBinding Light=#D9472B, Dark=#C03D22}"
                                TextColor="White"
                                CornerRadius="8" HeightRequest="40"
                                Command="{Binding ExportDataCommand}"
                                SemanticProperties.Hint="Exports your food log backup as a CSV file" />
                    </Grid>

                    <BoxView HeightRequest="1"
                             Color="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}" />

                    <!-- Clear Image Cache -->
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Clear Image Cache"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#3A2518, Dark=#FFF2DF}" />
                            <Label Text="Remove locally cached food images to reclaim storage space."
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light=#8B6D55, Dark=#BFA58E}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1"
                                Text="🗑 Clear"
                                FontAttributes="Bold" FontSize="13"
                                BackgroundColor="{AppThemeBinding Light=#8B6D55, Dark=#5A4A38}"
                                TextColor="White"
                                CornerRadius="8" HeightRequest="40"
                                Command="{Binding ClearImageCacheCommand}"
                                SemanticProperties.Hint="Clears all locally cached image files" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- ═══════════════════════════════════════════
                 ABOUT CARD
                 ═══════════════════════════════════════════ -->
            <Border StrokeThickness="1" Padding="18"
                    Stroke="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#1A1712}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">

                    <Label Text="ℹ️  About"
                           FontSize="18" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#D9472B, Dark=#FF9C7B}"
                           SemanticProperties.HeadingLevel="Level2" />

                    <BoxView HeightRequest="1"
                             Color="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}" />

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="App Version"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#3A2518, Dark=#FFF2DF}" />
                            <Label Text="NutriBite — your personal food diary companion."
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light=#8B6D55, Dark=#BFA58E}" />
                        </VerticalStackLayout>
                        <Frame Grid.Column="1"
                               BackgroundColor="{AppThemeBinding Light=#FFF0D0, Dark=#2A2417}"
                               BorderColor="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}"
                               CornerRadius="8" Padding="12,6"
                               HasShadow="False">
                            <Label Text="{Binding AppVersion}"
                                   FontSize="15" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#A95517, Dark=#FFD18E}" />
                        </Frame>
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- Bottom spacer for comfortable scrolling -->
            <BoxView HeightRequest="20" Color="Transparent" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
