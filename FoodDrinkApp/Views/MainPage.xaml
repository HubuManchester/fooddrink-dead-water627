<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FoodDrinkApp.ViewModels"
             xmlns:models="clr-namespace:FoodDrinkApp.Models"
             xmlns:conv="clr-namespace:FoodDrinkApp.Converters"
             x:Class="FoodDrinkApp.Views.MainPage"
             x:DataType="vm:MainPageViewModel"
             Title="{Binding Title}"
             BackgroundColor="{AppThemeBinding Light=#FFF9EF, Dark=#0F1711}"
             SemanticProperties.Description="Foodie Log home screen — browse and search your food memory diary">

    <ContentPage.Resources>
        <conv:InvertBoolConverter x:Key="InvertBool" />
    </ContentPage.Resources>

    <!--
        Outer Grid handles the full-page layout.
        Row 4 uses Star so the list fills all remaining vertical space.
        The entire structure is wrapped once — no nested ScrollViews.
        On landscape the Grid columns stretch horizontally and the
        CollectionView fills the available area naturally.
    -->
    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*"
          Padding="20"
          RowSpacing="18">

        <!-- ══════════════ Welcome Header ══════════════ -->
        <VerticalStackLayout Spacing="6">
            <Label Text="🍜 Foodie Log"
                   FontSize="32"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#D9472B, Dark=#FF9C7B}"
                   SemanticProperties.HeadingLevel="Level1"
                   SemanticProperties.Description="Foodie Log — your personal food memory diary" />
            <Label Text="Record every delicious moment."
                   FontSize="15"
                   TextColor="{AppThemeBinding Light=#8B6D55, Dark=#D8C4AC}"
                   SemanticProperties.Description="Tap the add button to record a new food memory" />
        </VerticalStackLayout>

        <!-- ══════════════ Search + Add ══════════════ -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#1A1712}"
                    Padding="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <SearchBar x:Name="SearchBar"
                           Placeholder="Search memories..."
                           Text="{Binding SearchQuery}"
                           TextColor="{AppThemeBinding Light=#3A2518, Dark=#FFF2DF}"
                           PlaceholderColor="{AppThemeBinding Light=#9A7B63, Dark=#BFA58E}"
                           BackgroundColor="Transparent"
                           SemanticProperties.Description="Search through your food memories by name, restaurant, or location"
                           SemanticProperties.Hint="Type to search your food memories" />
            </Border>

            <Button Grid.Column="1"
                    Text="+ Add Memory"
                    FontAttributes="Bold"
                    FontSize="14"
                    BackgroundColor="{AppThemeBinding Light=#D9472B, Dark=#FF7D55}"
                    TextColor="#FFFFFF"
                    Command="{Binding GoToAddEntryCommand}"
                    SemanticProperties.Description="Navigate to the add food memory screen"
                    SemanticProperties.Hint="Add a new food memory entry" />
        </Grid>

        <!-- ══════════════ Loading indicator ══════════════ -->
        <ActivityIndicator Grid.Row="2"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           HeightRequest="36"
                           Color="{AppThemeBinding Light=#D9472B, Dark=#FF9C7B}"
                           SemanticProperties.Description="Loading food memories from the cloud" />

        <!-- ══════════════ Status banner ══════════════ -->
        <Border Grid.Row="3"
                IsVisible="{Binding HasStatusMessage}"
                StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light=#FFF3CD, Dark=#3A3520}"
                Padding="10,8">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>
            <Label Text="{Binding StatusMessage}"
                   FontSize="13"
                   TextColor="{AppThemeBinding Light=#856404, Dark=#FFE69C}"
                   HorizontalTextAlignment="Center"
                   SemanticProperties.Description="Status update from the app" />
        </Border>

        <!-- ══════════════ Content area (list + empty state) ══════════════ -->
        <Grid Grid.Row="4">

            <!-- ── Empty State ── -->
            <VerticalStackLayout IsVisible="{Binding IsEmpty}"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="16"
                                 Padding="32">
                <Label Text="🍱"
                       FontSize="72"
                       HorizontalOptions="Center"
                       SemanticProperties.Description="Bento box illustration representing an empty food diary" />
                <Label Text="Your food diary is empty"
                       FontSize="22"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center"
                       TextColor="{AppThemeBinding Light=#6E5A47, Dark=#D8C4AC}"
                       SemanticProperties.HeadingLevel="Level2"
                       SemanticProperties.Description="No food memories recorded yet" />
                <Label Text="Tap + Add Memory to capture your first delicious moment! 🍽️"
                       FontSize="15"
                       HorizontalTextAlignment="Center"
                       TextColor="{AppThemeBinding Light=#8B6D55, Dark=#BFA58E}"
                       SemanticProperties.Description="Tap the Add Memory button at the top to create your first food memory entry" />
            </VerticalStackLayout>

            <!-- ── RefreshView + CollectionView ── -->
            <RefreshView IsRefreshing="{Binding IsRefreshing}"
                         Command="{Binding RefreshCommand}"
                         IsVisible="{Binding IsEmpty, Converter={StaticResource InvertBool}}"
                         RefreshColor="{AppThemeBinding Light=#D9472B, Dark=#FF9C7B}"
                         SemanticProperties.Description="Pull down to refresh the food memory list"
                         SemanticProperties.Hint="Swipe down to reload from the cloud">
                <CollectionView ItemsSource="{Binding FoodMemories}"
                                SelectionMode="None"
                                SemanticProperties.Description="Scrollable list of your food memories. Swipe left on a card to delete it.">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:FoodModel">

                            <!-- ── SwipeView: left-to-reveal Delete ── -->
                            <SwipeView SemanticProperties.Description="Swipe left to reveal the delete option for this memory">
                                <SwipeView.RightItems>
                                    <SwipeItems>
                                        <SwipeItem Text="Delete"
                                                   BackgroundColor="#E53935"
                                                   Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainPageViewModel}}, Path=DeleteMemoryCommand}"
                                                   CommandParameter="{Binding .}"
                                                   SemanticProperties.Description="Delete this food memory"
                                                   SemanticProperties.Hint="Tap to permanently remove this food memory from your diary" />
                                    </SwipeItems>
                                </SwipeView.RightItems>

                                <!-- Card content (the swipe-away surface) -->
                                <Border StrokeThickness="1"
                                        Stroke="{AppThemeBinding Light=#F0D6B8, Dark=#3E3023}"
                                        BackgroundColor="{AppThemeBinding Light=#FFFFFA, Dark=#1A1712}"
                                        Padding="16"
                                        Margin="0,0,0,12">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12" />
                                    </Border.StrokeShape>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainPageViewModel}}, Path=GoToDetailCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>

                                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
                                        <!-- Dish name + rating -->
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Text="{Binding Name}"
                                                   FontSize="18"
                                                   FontAttributes="Bold"
                                                   TextColor="{AppThemeBinding Light=#3A2518, Dark=#FFF2DF}"
                                                   SemanticProperties.HeadingLevel="Level2"
                                                   SemanticProperties.Description="Dish or drink name" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding RatingLabel}"
                                                   FontSize="14"
                                                   TextColor="{AppThemeBinding Light=#D9472B, Dark=#FF9C7B}"
                                                   SemanticProperties.Description="Star rating" />
                                        </Grid>
                                        <!-- Restaurant + date -->
                                        <Label Grid.Row="1"
                                               Text="{Binding CardSubtitle}"
                                               FontSize="14"
                                               TextColor="{AppThemeBinding Light=#6E5A47, Dark=#D8C4AC}"
                                               SemanticProperties.Description="Restaurant and date" />
                                        <!-- Review snippet -->
                                        <Label Grid.Row="2"
                                               Text="{Binding Review}"
                                               FontSize="13"
                                               TextColor="{AppThemeBinding Light=#8B6D55, Dark=#BFA58E}"
                                               MaxLines="2"
                                               LineBreakMode="TailTruncation"
                                               SemanticProperties.Description="Review preview" />
                                    </Grid>
                                </Border>

                            </SwipeView>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </RefreshView>

        </Grid>

    </Grid>
</ContentPage>
