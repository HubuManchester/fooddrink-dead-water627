<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FoodDrinkApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:FoodDrinkApp.Views"
    Title="Foodie Log"
    FlyoutBehavior="Disabled"
    Shell.BackgroundColor="{AppThemeBinding Light=#FFF4E3, Dark=#120E0B}"
    Shell.ForegroundColor="{AppThemeBinding Light=#3A2518, Dark=#FFF2DF}"
    Shell.TitleColor="{AppThemeBinding Light=#3A2518, Dark=#FFF2DF}"
    Shell.UnselectedColor="{AppThemeBinding Light=#9A7B63, Dark=#BFA58E}"
    Shell.TabBarBackgroundColor="{AppThemeBinding Light=#FFF4E3, Dark=#120E0B}"
    Shell.TabBarForegroundColor="{AppThemeBinding Light=#D9472B, Dark=#FFB15D}"
    Shell.TabBarTitleColor="{AppThemeBinding Light=#D9472B, Dark=#FFB15D}"
    Shell.TabBarUnselectedColor="{AppThemeBinding Light=#9A7B63, Dark=#BFA58E}">

    <!--
        Foodie Log — our original Food and Drink memory app.
        MainPage is the sole startup page; AddEntryPage is reached
        via Shell navigation from the "+ Add Memory" button.
    -->
    <ShellContent
        Title="Foodie Log"
        ContentTemplate="{DataTemplate views:MainPage}"
        Route="MainPage" />

</Shell>
